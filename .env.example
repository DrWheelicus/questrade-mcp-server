# Required on first run — generate at https://www.questrade.com/api
QUESTRADE_REFRESH_TOKEN=

# "production" or "practice"
QUESTRADE_ENVIRONMENT=production

# "stdio" or "http"
QUESTRADE_MCP_TRANSPORT=stdio

# Port for HTTP transport (ignored in stdio mode)
QUESTRADE_MCP_PORT=3100

# Override the machine-derived encryption key for token storage (optional)
QUESTRADE_ENCRYPTION_KEY=
